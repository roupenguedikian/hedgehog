          "rawSql": "SELECT to_char(timestamp, 'YYYY-MM-DD HH24:MI:SS') AS \"Time\", symbol, side, ROUND(size::numeric, 6) AS \"Size\", ROUND(price::numeric, 2) AS \"Price\", ROUND(value::numeric, 2) AS \"Value $\", ROUND(fee::numeric, 4) AS \"Fee\", role FROM venue_fills WHERE venue = '${venue:raw}' ORDER BY timestamp DESC LIMIT 50",
