          "rawSql": "SELECT timestamp AS time, nav AS \"NAV\", margin_used AS \"Margin Used\", free_margin AS \"Margin Free\", unrealized_pnl AS \"UPnL\" FROM venue_accounts WHERE venue = '${venue:raw}' AND $__timeFilter(timestamp) ORDER BY timestamp",
