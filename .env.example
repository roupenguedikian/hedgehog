# HedgeHog Protocol — Environment Variables
# Copy to .env and fill in your values

# ═══════════════════════════════════════════════════════════
# EXCHANGES — credentials
# ═══════════════════════════════════════════════════════════

# Hyperliquid
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_PRIVATE_KEY=

# dYdX v4 (Cosmos)
DYDX_WALLET_ADDRESS=
DYDX_MNEMONIC=

# Drift (Solana)
DRIFT_RPC_URL=
DRIFT_WALLET_ADDRESS=
DRIFT_PRIVATE_KEY=

# Lighter (ZK-rollup)
LIGHTER_API_KEY=
LIGHTER_API_KEY_PRIVATE_KEY=
LIGHTER_ACCOUNT_INDEX=
LIGHTER_API_KEY_INDEX=

# Apex Omni (zkLink/StarkNet)
APEX_OMNI_API_KEY=
APEX_OMNI_API_SECRET=
APEX_OMNI_WALLET_ADDRESS=
APEX_OMNI_PRIVATE_KEY=
APEX_OMNI_PASSPHRASE=
APEX_OMNI_SEEDS=

# Aster — V1 (HMAC) auth
ASTER_API_KEY=
ASTER_API_SECRET=

# EdgeX (secp256k1 ECDSA + SHA3 signing)
EDGEX_ACCOUNT_ID=726551980876496932
EDGEX_PRIVATE_KEY=

# Paradex (StarkNet L2)
PARADEX_L2_ADDRESS=
PARADEX_L2_PRIVATE_KEY=

# Ethereal (EVM, Converge chain)
ETHEREAL_WALLET_ADDRESS=         # 0x... wallet address for account queries
ETHEREAL_PRIVATE_KEY=            # EVM private key for order signing

# trade.xyz / XYZ (HIP-3 on Hyperliquid — uses HL wallet)
TRADEXYZ_WALLET_ADDRESS=     

# ═══════════════════════════════════════════════════════════
# API Keys
# ═══════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=
COINGLASS_API_KEY=

# ═══════════════════════════════════════════════════════════
# Alerting
# ═══════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════
# Database (must match docker-compose.yml TimescaleDB config)
# ═══════════════════════════════════════════════════════════
DB_PASSWORD=aegis_dev
DATABASE_URL=postgresql://aegis:aegis_dev@timescaledb:5432/aegis
REDIS_URL=redis://redis:6379/0

# Grafana
GRAFANA_PASSWORD=admin

# ═══════════════════════════════════════════════════════════
# HEDGE THRESHOLDS — entry / rotation / exit criteria
# Yields are decimals (0.0008 = 0.08% daily)
# Breakeven is always in hours
# ═══════════════════════════════════════════════════════════

# Active symbols the bot can trade (comma-separated)
ACTIVE_SYMBOLS=BTC,ETH,SOL,ARB,DOGE,AVAX,LINK,SUI,WIF,PEPE,AAVE,NEAR

# Entry: minimum net daily yield and max breakeven hours to open a new hedge
ENTRY_NDPY=0.0008
ENTRY_BREAKEVEN=12

# Rotation: max breakeven hours on rotation cost
ROTATION_NDPY=0.0003
ROTATION_BREAKEVEN=6

# Exit: close if net daily yield drops below this
EXIT_NDPY=0.0003
