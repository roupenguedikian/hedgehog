# HedgeHog Protocol — Environment Variables
# Copy to .env and fill in your values

# Wallet Keys
EVM_PRIVATE_KEY=
DRIFT_PRIVATE_KEY=
DYDX_MNEMONIC=
PARADEX_STARK_KEY=

# Aster — V1 (HMAC) auth
ASTER_API_KEY=
ASTER_API_SECRET=

# Aster — V3 (EIP-712) auth (preferred)
ASTER_USER_ADDRESS=              # Main wallet address (0x...)
ASTER_SIGNER_ADDRESS=            # API wallet address (0x...)
ASTER_SIGNER_PRIVATE_KEY=        # API wallet private key

# API Keys
ANTHROPIC_API_KEY=
COINGLASS_API_KEY=

# Alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database (must match docker-compose.yml TimescaleDB config)
DB_PASSWORD=aegis_dev
DATABASE_URL=postgresql://aegis:aegis_dev@timescaledb:5432/aegis
REDIS_URL=redis://redis:6379/0

# Grafana
GRAFANA_PASSWORD=admin
