{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 2,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Venues Online",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        { "expr": "hedgehog_venues_healthy", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#56A64B", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Opportunities",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        { "expr": "hedgehog_opportunities_found", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#FF9830", "value": null },
              { "color": "#56A64B", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Best Spread (ann.)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        { "expr": "max(hedgehog_best_spread_annualized) * 100", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#E02F44", "value": null },
              { "color": "#FF9830", "value": 5 },
              { "color": "#56A64B", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Highest 1h Rate",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        { "expr": "max(hedgehog_funding_rate_annualized{venue=~\"$venue\"}) / 8760 * 100", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#3274D9", "value": null },
              { "color": "#56A64B", "value": 0 },
              { "color": "#FF9830", "value": 0.005 },
              { "color": "#E02F44", "value": 0.01 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      }
    },

    {
      "id": 10,
      "type": "row",
      "title": "$symbol Funding Rates",
      "repeat": "symbol",
      "repeatDirection": "h",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "panels": []
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Current 1h Rate",
      "gridPos": { "h": 9, "w": 7, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        {
          "expr": "sort_desc(hedgehog_funding_rate_annualized{symbol=\"$symbol\", venue=~\"$venue\"} / 8760 * 100)",
          "refId": "A",
          "instant": true,
          "legendFormat": "{{venue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#3274D9", "value": null },
              { "color": "#37872D", "value": 0 },
              { "color": "#E0B400", "value": 0.002 },
              { "color": "#FF9830", "value": 0.005 },
              { "color": "#E02F44", "value": 0.01 }
            ]
          },
          "color": { "mode": "thresholds" },
          "min": -0.005,
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "sizing": "auto",
        "namePlacement": "auto"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Rate History (1h)",
      "gridPos": { "h": 9, "w": 17, "x": 7, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        {
          "expr": "hedgehog_funding_rate_annualized{symbol=\"$symbol\", venue=~\"$venue\"} / 8760 * 100",
          "refId": "A",
          "legendFormat": "{{venue}}"
        },
        {
          "expr": "hedgehog_funding_rate_predicted{symbol=\"$symbol\", venue=~\"$venue\"} / 8760 * 100",
          "refId": "B",
          "legendFormat": "{{venue}} (predicted)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 8,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "axisBorderShow": false,
            "axisLabel": "",
            "scaleDistribution": { "type": "linear" },
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "transparent", "value": null }]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.lineWidth", "value": 1 },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull", "mean"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },

    {
      "id": 20,
      "type": "row",
      "title": "Arbitrage Spreads",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "panels": []
    },
    {
      "id": 21,
      "type": "table",
      "title": "Current Spread Opportunities",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        {
          "expr": "hedgehog_best_spread_annualized",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true,
            "cellOptions": { "type": "auto" }
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "symbol" },
            "properties": [
              { "id": "displayName", "value": "Symbol" },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "short_venue" },
            "properties": [
              { "id": "displayName", "value": "Short Venue" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "long_venue" },
            "properties": [
              { "id": "displayName", "value": "Long Venue" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Spread (ann.)" },
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "gradient" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#E02F44", "value": null },
                    { "color": "#FF9830", "value": 0.05 },
                    { "color": "#56A64B", "value": 0.10 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Spread (ann.)", "desc": true }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "symbol": 0,
              "short_venue": 1,
              "long_venue": 2,
              "Value": 3
            }
          }
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Top Spreads Over Time",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        {
          "expr": "topk(5, hedgehog_best_spread_annualized) * 100",
          "refId": "A",
          "legendFormat": "{{symbol}} {{short_venue}}\u2192{{long_venue}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "axisBorderShow": false,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "transparent", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "24h Rate Analysis",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "panels": []
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "24h Mean Rate by Venue (1h)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        {
          "expr": "hedgehog_funding_rate_mean_24h{symbol=~\"$symbol\", venue=~\"$venue\"} / 8760 * 100",
          "refId": "A",
          "legendFormat": "{{venue}} ({{symbol}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 4,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "axisBorderShow": false,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "transparent", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Rate Volatility (24h Std Dev)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        {
          "expr": "hedgehog_funding_rate_std_24h{symbol=~\"$symbol\", venue=~\"$venue\"}",
          "refId": "A",
          "legendFormat": "{{venue}} ({{symbol}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 6,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "axisBorderShow": false,
            "stacking": { "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "transparent", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 33,
      "type": "bargauge",
      "title": "Sign Flips (24h)",
      "description": "Number of times the funding rate changed sign in the last 24 hours. More flips = less predictable.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
      "targets": [
        {
          "expr": "hedgehog_funding_rate_flips_24h{symbol=~\"$symbol\", venue=~\"$venue\"}",
          "refId": "A",
          "instant": true,
          "legendFormat": "{{venue}} ({{symbol}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#56A64B", "value": null },
              { "color": "#E0B400", "value": 3 },
              { "color": "#FF9830", "value": 6 },
              { "color": "#E02F44", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 8,
        "minVizHeight": 16,
        "sizing": "auto",
        "namePlacement": "auto"
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hedgehog", "funding-rates"],
  "templating": {
    "list": [
      {
        "name": "symbol",
        "label": "Symbol",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
        "query": "label_values(hedgehog_funding_rate_annualized, symbol)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "venue",
        "label": "Venue",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "hedgehog-prometheus" },
        "query": "label_values(hedgehog_funding_rate_annualized, venue)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Funding Rates",
  "uid": "hedgehog-funding",
  "version": 1
}
