    {
      "type": "timeseries",
      "title": "Best Spread History (${symbol})",
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 57
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "WITH ranked AS (  SELECT time_bucket('5 minutes', timestamp) AS time, venue,   AVG(predicted_rate * 8760 * 100) AS rate   FROM funding_rates   WHERE $__timeFilter(timestamp) AND symbol = '${symbol:raw}'   GROUP BY time, venue) SELECT time, MAX(rate) - MIN(rate) AS \"Spread %\" FROM ranked GROUP BY time ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "showPoints": "never",
            "spanNulls": true,
            "gradientMode": "opacity"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Spread %"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#06b6d4"
                }
              }
            ]
          }
        ]
      },
