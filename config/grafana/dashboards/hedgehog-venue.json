    {
      "type": "timeseries",
      "title": "Predicted Rates \u2014 All Symbols (annualized %)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT time_bucket('5 minutes', timestamp) AS time, symbol, AVG(predicted_rate) * 8760 * 100 AS rate FROM funding_rates WHERE venue = '${venue:raw}' AND $__timeFilter(timestamp) GROUP BY time, symbol ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": true,
            "gradientMode": "opacity"
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "type": "table",
      "title": "Current Rates",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT symbol, ROUND((predicted_rate * 8760 * 100)::numeric, 2) AS \"Predicted (ann%)\", ROUND((rate * 8760 * 100)::numeric, 2) AS \"Settled (ann%)\", cycle_hours AS \"Cycle (h)\", ROUND(mark_price::numeric, 2) AS \"Mark\" FROM latest_rates WHERE venue = '${venue:raw}' ORDER BY ABS(predicted_rate) DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Predicted (ann%)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [],
        "filterable": true,
        "footer": {
          "show": false
        }
      },
      "transformations": []
    },
